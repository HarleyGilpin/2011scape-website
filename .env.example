APP_NAME="2011scape"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=https://2011.rs

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=site2011
DB_USERNAME=site2011
DB_PASSWORD=

GAME_DB_HOST=127.0.0.1
GAME_DB_PORT=5432
GAME_DB_DATABASE=game
GAME_DB_USERNAME=postgres
GAME_DB_PASSWORD=
GAME_LOG_DIR=
GAME_ITEMS_JSON=

XENFORO_URL=https://2011.rs/services/m=forum
XENFORO_API_KEY=
XENFORO_API_USER=1
XENFORO_COOKIE_PREFIX=xf_

GAME_PASSWORD_ALGO=bcrypt

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@2011.rs"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
